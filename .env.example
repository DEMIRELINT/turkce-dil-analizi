# Gemini API anahtarı (geliştirme ortamı). Üretimde (Faz 8) yerel uçlarla değişir.
GEMINI_API_KEY=

# Kullanılacak Gemini modeli.
# Geliştirme/eval için flash-lite önerilir: ücretsiz katmanda en bol günlük kota.
# Nihai kalite kontrolü için ara sıra gemini-2.5-flash / -pro kullanılabilir.
MODEL_ID=gemini-2.5-flash-lite

# Üretim sıcaklığı: tutarlılık için 0.
TEMPERATURE=0

# Uzun belge parçalarının eşzamanlı işlenme sayısı (paralellik).
# LLM çağrıları ağ-bağımlı olduğundan paralellik toplam süreyi kısaltır; çıktı
# birebir aynı kalır. CONCURRENCY=1 → tamamen sıralı (eski) davranış.
CONCURRENCY=6

# Air-gap hijyeni: LangSmith telemetrisi kapalı kalsın.
LANGSMITH_TRACING=false

# Kural dökümanı yolu (opsiyonel). Boşsa paketteki rules.md kullanılır.
# Resmî/kurumsal kural dökümanını koymak için buraya o dosyanın yolunu yaz —
# kod değişmez. Örn: RULES_PATH=/Users/demirel/Desktop/a-proje/kurallar/resmi.md
RULES_PATH=

# Gemini istemci taşıma katmanı (opsiyonel). Boşsa SDK varsayılanı (grpc)
# kullanılır. Bazı kurumsal ağlarda güvenlik duvarı/proxy grpc'nin HTTP/2
# trafiğini sessizce düşürebiliyor (bağlantı donar, hata bile vermez) —
# düz HTTPS/REST çalışıyorsa bunu "rest" yaparak istemciyi REST'e zorla.
# Seçenekler: rest | grpc | grpc_asyncio
GOOGLE_GENAI_TRANSPORT=

# Tek bir LLM çağrısı için üst zaman aşımı (saniye). Bağlantı yarıda tıkanırsa
# (kurumsal ağda güvenlik duvarı gibi) çağrının sonsuza kadar asılı kalmasını
# önler. 0 veya boş → sınırsız (istemci varsayılanı).
LLM_TIMEOUT_SEC=60
